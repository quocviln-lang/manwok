// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  SYSTEM_USER
  SYSTEM_ADMIN
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  fullName   String     @map("full_name")
  avatar     String?
  systemRole SystemRole @default(SYSTEM_USER) @map("system_role")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  isActive   Boolean    @default(true) @map("is_active")

  // Relations
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
  createdCards     Card[]            @relation("CardCreator")
  assignedCards    CardAssignee[]
  comments         Comment[]
  notifications      Notification[]
  commentReactions   CommentReaction[]
  activities         Activity[]
  workspaceInvites   WorkspaceInvite[] // Invites sent by this user
  workspaceActivities WorkspaceActivity[]
  boardJoinRequests  BoardJoinRequest[]
  createdBoards      Board[]           @relation("BoardCreator")

  @@map("users")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String   @map("owner_id")
  settings    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  owner      User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    WorkspaceMember[]
  invites    WorkspaceInvite[]
  boards     Board[]
  activities WorkspaceActivity[]

  @@map("workspaces")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum BoardVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
}

model Board {
  id          String          @id @default(uuid())
  workspaceId String          @map("workspace_id")
  title       String
  description String?
  color       String?         @default("#0079BF")
  cover       String?
  archived    Boolean         @default(false)
  visibility  BoardVisibility @default(WORKSPACE)
  creatorId   String?         @map("creator_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator      User?      @relation("BoardCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  lists        List[]
  activities   Activity[]
  joinRequests BoardJoinRequest[]

  @@map("boards")
}

model List {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  title     String
  color     String?
  position  Float
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@map("lists")
}

model Card {
  id          String   @id @default(uuid())
  listId      String   @map("list_id")
  title       String
  description String?
  cover       String?
  position    Float
  isCompleted Boolean  @default(false)
  archived    Boolean  @default(false)
  createdById String    @map("created_by_id")
  startDate   DateTime? @map("start_date")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  list        List             @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("CardCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignees   CardAssignee[]
  comments    Comment[]
  checklists  Checklist[]
  attachments Attachment[]

  @@map("cards")
}

model CardAssignee {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@map("card_assignees")
}

model Comment {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  card      Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  @@map("comments")
}

enum NotificationType {
  CARD_ASSIGNED
  COMMENT_ADDED
  SYSTEM_ALERT
  WORKSPACE_INVITE
  BOARD_JOIN_REQUEST
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  relatedId String?          @map("related_id") // Optional ID related to the notification (e.g., Card ID)
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Checklist {
  id        String          @id @default(uuid())
  cardId    String          @map("card_id")
  title     String
  position  Float
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  // Relations
  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@map("checklists")
}

model ChecklistItem {
  id          String   @id @default(uuid())
  checklistId String   @map("checklist_id")
  content     String
  isCompleted Boolean  @default(false) @map("is_completed")
  position    Float

  // Relations
  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model Attachment {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  url       String
  name      String
  type      String   // "link" or "file" or "image"
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model CommentReaction {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

model Activity {
  id         String   @id @default(uuid())
  boardId    String   @map("board_id")
  userId     String   @map("user_id")
  action     String   // e.g., CREATE_CARD, MOVE_CARD, ARCHIVE_LIST, RESTORE_LIST
  entityType String   @map("entity_type") // e.g., CARD, LIST
  entityId   String   @map("entity_id")
  entityTitle String? @map("entity_title") // Store title here so we don't need to join if the entity is deleted
  details    Json?    
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model WorkspaceInvite {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  email       String
  role        String   @default("MEMBER")
  inviterId   String   @map("inviter_id")
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("workspace_invites")
}

model WorkspaceActivity {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  action      String   // e.g., CREATE_BOARD, DELETE_BOARD, ARCHIVE_BOARD, ADD_MEMBER, REMOVE_MEMBER
  entityType  String   @map("entity_type") // e.g., BOARD, MEMBER
  entityId    String   @map("entity_id")
  entityTitle String?  @map("entity_title")
  details     Json?    
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workspace_activities")
}

model BoardJoinRequest {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  userId    String   @map("user_id")
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("board_join_requests")
}
